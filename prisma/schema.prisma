// ==========================================
// TIA MAI - SCHEMA DO BANCO DE DADOS
// PostgreSQL (Supabase)
// ==========================================

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  ADMIN
  TEAM
}

enum ProjectType {
  INTERIOR
  ARCHITECTURAL
}

enum ProjectStatus {
  PROSPECT
  ACTIVE
  PAUSED
  FINISHED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CertificateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  CONTRACT
  PLAN
  PHOTO
  RRT
  OTHER
}

enum PaymentType {
  CASH_UPFRONT
  INSTALLMENTS
  UPFRONT_AND_INSTALLMENTS
}

// ==========================================
// MODELS
// ==========================================

model User {
  id        String   @id @default(uuid())
  name      String
  username  String   @unique
  password  String
  role      Role     @default(TEAM)
  avatarUrl String?  @map("avatar_url")
  lastLogin DateTime? @map("last_login")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  // Relations
  creator          User?            @relation("UserCreator", fields: [createdBy], references: [id])
  createdUsers     User[]           @relation("UserCreator")
  assignedTasks    Task[]           @relation("TaskAssignee")
  assignedProjects Project[]        @relation("ProjectAssignee")
  certificates     Certificate[]
  projectHistories ProjectHistory[]

  @@map("users")
}

model Client {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  address     String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  projects Project[]

  @@map("clients")
}

model Project {
  id         String        @id @default(uuid())
  name       String
  clientId   String?       @map("client_id")
  type       ProjectType
  status     ProjectStatus @default(PROSPECT)
  deadline   DateTime?
  totalValue   Decimal?      @map("total_value") @db.Decimal(12, 2)
  paymentType  PaymentType   @default(CASH_UPFRONT) @map("payment_type")
  installments Int?          @default(1)
  upfrontValue Decimal?      @map("upfront_value") @db.Decimal(12, 2)
  notes        String?
  assignedTo   String?       @map("assigned_to")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  client       Client?              @relation(fields: [clientId], references: [id])
  assignee     User?                @relation("ProjectAssignee", fields: [assignedTo], references: [id])
  phases       Phase[]
  documents    Document[]
  transactions FinancialTransaction[]
  history      ProjectHistory[]

  @@map("projects")
}

model ProjectHistory {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  dataSnapshot Json     @map("data_snapshot")
  changedAt    DateTime @default(now()) @map("changed_at")
  changedBy    String   @map("changed_by")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [changedBy], references: [id])

  @@map("project_history")
}

model Phase {
  id        String      @id @default(uuid())
  projectId String      @map("project_id")
  name      String
  order     Int
  status        PhaseStatus @default(PENDING)
  deadline      DateTime?
  justification String?
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relations
  project Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
  documents Document[]

  @@map("phases")
}

model Task {
  id          String   @id @default(uuid())
  phaseId     String   @map("phase_id")
  description String
  isCompleted Boolean  @default(false) @map("is_completed")
  assignedTo  String?  @map("assigned_to")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  phase    Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assignedTo], references: [id])

  @@map("tasks")
}

model Document {
  id        String       @id @default(uuid())
  projectId String       @map("project_id")
  phaseId   String?      @map("phase_id")
  name      String
  fileUrl   String       @map("file_url")
  type      DocumentType @default(OTHER)
  createdAt DateTime     @default(now()) @map("created_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   Phase?  @relation(fields: [phaseId], references: [id])

  @@map("documents")
}

model FinancialTransaction {
  id              String          @id @default(uuid())
  projectId       String?         @map("project_id")
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  transactionDate DateTime        @map("transaction_date")
  description     String?
  category        String?
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  project Project? @relation(fields: [projectId], references: [id])

  @@map("financial_transactions")
}

model Certificate {
  id          String            @id @default(uuid())
  userId      String            @map("user_id")
  absenceDate DateTime          @map("absence_date")
  fileUrl     String            @map("file_url")
  description String?
  status      CertificateStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}
